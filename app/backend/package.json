{
  "name": "backend",
  "private": true,
  "scripts": {
    "dev:hot": "bun --hot run src/index.ts",
    "dev:run": "bun run src/index.ts",
    "dev:start": "bun ./dist/index.js",
    "dev:build": "bun build --entrypoints --sourcemap ./src/index.ts --outdir ./dist --target bun",
    "deploy:build": "bun build --plugin ./src/plugin/index.ts --compile --minify --sourcemap --target=bun-linux-x64 ./src/index.ts --outfile ./dist/application"
  },
  "engines": {
    "node": ">=24.12.0",
    "bun": ">=1.3.13"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "eslint": "^10.5.0",
    "eslint-prettier-config": "^1.0.1",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@types/pg": "^8.20.0",
    "@types/pg-format": "^1.0.5",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "pg-format": "^1.0.4",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  }
}
